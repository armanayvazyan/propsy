<idea-plugin>
    <id>io.github.armanayvazyan.propsy</id>
    <name>Propsy</name>
    <vendor>armanayvazyan</vendor>

    <description><![CDATA[
        Shows configured .properties files as an editable Key/Value table in a tool window.
        Paths are configured per-project in Settings | Tools | Propsy.
        Edits preserve comments, blank lines and key order.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.properties</depends>
    <!--
      Intentionally NO <depends> on ru.adelf.idea.dotenv. DotEnvBackend is registered
      unconditionally below and gates itself at runtime on DotEnvPlugin.isActive() (queried
      via PluginManager). This keeps .env support immune to plugin load order: enabling the
      dotenv plugin after Propsy has already loaded takes effect on Refresh, with no restart.
    -->


    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="io.github.armanayvazyan.propsy.PropsySettings"/>
        <projectConfigurable
                parentId="tools"
                instance="io.github.armanayvazyan.propsy.PropsyConfigurable"
                id="io.github.armanayvazyan.propsy.settings"
                displayName="Propsy"/>
        <toolWindow
                id="Propsy"
                anchor="bottom"
                icon="/icons/propsy.svg"
                factoryClass="io.github.armanayvazyan.propsy.PropsyToolWindowFactory"/>
    </extensions>

    <extensionPoints>
        <extensionPoint name="backend"
                        interface="io.github.armanayvazyan.propsy.PropsyBackend"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="io.github.armanayvazyan.propsy">
        <backend implementation="io.github.armanayvazyan.propsy.PropertiesBackend"/>
        <backend implementation="io.github.armanayvazyan.propsy.DotEnvBackend"/>
    </extensions>

    <applicationListeners/>
</idea-plugin>
